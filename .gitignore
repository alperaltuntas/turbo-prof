# Python
__pycache__/
*.pyc

# Profiler artifacts (large, regenerable)
*.nsys-rep
*.sqlite

# Raw run outputs (the committed report distills these)
*_[0-9][0-9][0-9].out
*_[0-9][0-9][0-9].err
logfile.*
*.nc
RESTART/
INPUT/

# PBS job spool (stdout/stderr left in the submit dir, e.g. mom6_standalone_gpu.o123456)
*.o[0-9]*
*.e[0-9]*

# Scratch report dirs anywhere (committed reports live under reports/, plural)
report/
report_*/
